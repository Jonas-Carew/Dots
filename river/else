
# Launch riveroverflow
riverctl spawn "riveroverflow"

# Set the default layout
riverctl default-layout riveroverflow

# Configure the layout manager
riverctl send-layout-cmd riveroverflow "main_count 2"
riverctl send-layout-cmd riveroverflow "main_ratio 0.5"
riverctl send-layout-cmd riveroverflow "view_padding 4"
riverctl send-layout-cmd riveroverflow "outer_padding 4"
riverctl send-layout-cmd riveroverflow "view_per_page 4"

# Set up a few key binds
riverctl map normal Super+Control J send-layout-cmd riveroverflow page_down
riverctl map normal Super+Control K send-layout-cmd riveroverflow page_up

riverctl map normal Super+Shift Return spawn wezterm
riverctl map normal Super Q close
riverctl map normal Super+Shift E exit
riverctl map normal Super Return spawn "tofi-run | xargs riverctl spawn"

